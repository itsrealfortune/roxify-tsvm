{
	"name": "roxify-tsvm",
	"version": "1.0.0",
	"license": "MIT",
	"description": "roxify command for typescript-virtual-container virtual shells — encode and decode files as PNG steganography archives.",
	"repository": {
		"type": "git",
		"url": "https://github.com/itsrealfortune/roxify-tsvm"
	},
	"keywords": [
		"roxify",
		"steganography",
		"png",
		"typescript-virtual-container",
		"virtual-shell",
		"shell-command"
	],
	"main": "dist/index.js",
	"module": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"type": "module",
	"scripts": {
		"build": "tsc --project tsconfig.json",
		"build:watch": "tsc --watch",
		"typecheck": "tsc --noEmit",
		"format": "bunx --bun @biomejs/biome format --write ./src",
		"check": "bunx --bun @biomejs/biome check ./src",
		"lint": "bunx --bun @biomejs/biome lint ./src",
		"lint:write": "bunx --bun @biomejs/biome lint --write ./src",
		"deploy:npm": "bun publish --access public",
		"publish-package": "bash ./scripts/publish-package.sh"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@types/bun": "^1.3.14",
		"@types/node": "^25.8.0",
		"typescript": "^6.0.3"
	},
	"peerDependencies": {
		"typescript-virtual-container": "^1.5.10"
	},
	"dependencies": {
		"roxify": "^1.16.9"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"cpu-features",
			"esbuild",
			"roxify",
			"ssh2",
			"typescript-virtual-container"
		]
	}
}
